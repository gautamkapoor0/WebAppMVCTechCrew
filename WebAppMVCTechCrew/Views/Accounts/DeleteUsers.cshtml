@model WebAppMVCTechCrew.Models.UsersModel
@{
    ViewData["Title"] = "DeleteUsers";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}



<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Delete User</h4>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning">
                        <strong>Warning!</strong> Are you sure you want to delete this user?
                    </div>

                    <table class="table table-bordered">
                        <tr>
                            <th>User ID</th>
                            <td>@Model.ID</td>
                        </tr>
                        <tr>
                            <th>Name</th>
                            <td>@Model.Username</td>
                        </tr>
                        <tr>
                            <th>Email</th>
                            <td>@Model.Email</td>
                        </tr>
                       
                    </table>

                    <form asp-action="DeleteUsers">
                        <input type="hidden" asp-for="ID" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="DisplayUsers" class="btn btn-secondary">
                                Back
                            </a>

                            <button type="submit" class="btn btn-danger">
                                Delete User
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>